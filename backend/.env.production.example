# Production environment variables for backend (Render Web Service)
# These are injected via Render dashboard — never commit actual values to git
#
# For Spring Boot, env vars are read as UPPER_SNAKE_CASE and mapped to application.yml
# Example: SPRING_DATASOURCE_URL → spring.datasource.url
#
# Reference: backend/src/main/resources/application.yml and infra/render-deployment-plan.md

# Spring configuration
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL connection (from Render managed database)
# Convert postgres:// to jdbc:postgresql:// when pasting from Render dashboard
DATABASE_URL=jdbc:postgresql://dpg-xxx.singapore-postgres.render.com/fashion_rental
DATABASE_USERNAME=fashion_user
DATABASE_PASSWORD=your_strong_password_here

# JWT authentication
# Generate with: openssl rand -base64 48
JWT_SECRET=your_48_char_random_base64_string_here

# Application credentials
APP_USERNAME=admin
APP_PASSWORD=your_strong_password_here

# CORS allowed origins
ALLOWED_ORIGINS=https://yourshop.in

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=fashion-rental
R2_PUBLIC_URL_BASE=https://pub-xxx.r2.dev

# Optional: Sentry error tracking
# SENTRY_DSN=https://your_sentry_dsn
