# Local development environment variables for frontend
# Copy this to .env.local to override defaults during development
# .env.local is gitignored and should never be committed
#
# This is optional — the app works fine without it because Vite's dev proxy
# handles /api requests by default (see vite.config.ts)

# Explicit API URL (optional in dev)
# If not set, the app uses Vite's proxy: /api → http://localhost:8080/api

# VITE_API_URL=http://localhost:8080
